{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/west-hills-capital build",
  "outputDirectory": "artifacts/west-hills-capital/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://workspaceapi-server-production-987b.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
