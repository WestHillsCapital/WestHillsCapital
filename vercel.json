{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/west-hills-capital build",
  "outputDirectory": "artifacts/west-hills-capital/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR_API_SERVER_URL/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
