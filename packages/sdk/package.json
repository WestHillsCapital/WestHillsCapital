{
  "name": "@docuplete/sdk",
  "version": "0.1.0",
  "description": "Official Node.js SDK for the Docuplete API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm generate:types && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "generate:types": "openapi-typescript ../../artifacts/api-server/src/lib/openapi-spec.json -o src/openapi.d.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "docuplete",
    "document",
    "pdf",
    "sdk",
    "api-client"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.5.0"
  }
}
