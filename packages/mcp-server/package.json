{
  "name": "@docupleteapp/mcp-server",
  "version": "0.1.2",
  "description": "Official Docuplete MCP server — control document automation from Claude Desktop, Cursor, and any MCP-compatible AI client",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "docuplete-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node' --external:@modelcontextprotocol/sdk --external:zod",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "docuplete",
    "mcp",
    "model-context-protocol",
    "document",
    "pdf",
    "ai",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@docuplete/sdk": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.5.0"
  }
}
