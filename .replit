modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "docufill-redaction"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "db-deps"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-west-hills-chart"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "workspace-typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "e2e-mapper"

[[workflows.workflow]]
name = "docufill-redaction"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node --experimental-transform-types scripts/validate-docufill-redaction.mjs"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "db-deps"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check-db-deps"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-west-hills-chart"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/west-hills-capital test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "workspace-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/west-hills-capital typecheck"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "e2e-mapper"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/west-hills-capital test"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

