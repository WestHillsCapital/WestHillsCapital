{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "dev:watch": "NODE_ENV=development tsx watch src/index.ts",
    "worker-dev": "export NODE_ENV=development && pnpm run build && pnpm run worker-start",
    "worker-start": "node --enable-source-maps ./dist/worker.mjs",
    "build": "node ./build.mjs",
    "start": "exec node --enable-source-maps ./dist/index.mjs",
    "test": "node --import tsx/esm --test-force-exit --test \"src/tests/*.test.ts\"",
    "test:coverage": "node --import tsx/esm --test-force-exit --experimental-test-coverage --test \"src/tests/*.test.ts\"",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc -p tsconfig.json --noEmit",
    "validate-sitemap": "node scripts/validate-sitemap.mjs",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clerk/express": "^2.1.9",
    "@google-cloud/storage": "^7.19.0",
    "@node-saml/node-saml": "^5.1.0",
    "@sentry/node": "^10.50.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "@workspace/queues": "workspace:*",
    "archiver": "^7.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "express": "^5",
    "geoip-lite": "1.4.10",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "otplib": "^13.4.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "pino-pretty": "^13",
    "qrcode": "^1.5.4",
    "stripe": "^22.1.0",
    "stripe-replit-sync": "^1.0.0",
    "svix": "^1.92.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "thread-stream": "3.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@docuplete/sdk": "workspace:*",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.2.2",
    "tsx": "catalog:"
  }
}
